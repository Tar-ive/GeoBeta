# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Option A: single connection URL
NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Option B: individual components (used if NEON_DATABASE_URL is not set)
PG_HOST=ep-xxx-pooler.us-east-1.aws.neon.tech
PG_PORT=5432
PG_DATABASE=neondb
PG_USER=neondb_owner
PG_PASSWORD=
PG_SSLMODE=require

# ── External APIs ─────────────────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=
KALSHI_API_KEY=
ANTHROPIC_API_KEY=
# EDGAR is public — no key needed

# ── FastAPI middleware ────────────────────────────────────────────────────────
API_KEY=your-generated-api-key-for-dashboard-clients
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit dashboard ───────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
USE_MOCK=false

# ── Zerve (configure as Zerve Secrets, not local env vars) ───────────────────
# NEON_DATABASE_URL    ← add to Zerve canvas secrets
# ALPHA_VANTAGE_KEY    ← add to Zerve canvas secrets
# FRED_API_KEY         ← add to Zerve canvas secrets
# ANTHROPIC_API_KEY    ← add to Zerve canvas secrets
